@model HeroModel

<section class="py-5 bg-light" @Html.StoryblokEditable(Model)>
    <div class="container py-5">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">

                <!-- Tagline -->
                <p class="text-uppercase text-primary fw-semibold small mb-3">
                    @Model.Tagline
                </p>

                <!-- Title -->
                <h1 class="display-4 fw-bold mb-4">
                    @Model.Title
                </h1>

                <!-- Description -->
                <p class="lead text-muted mb-5">
                    @Html.StoryblokRichText(Model.Description)
                </p>

                <!-- CTAs -->
                @if (Model.Ctas is { Length: > 0 })
                {
                    <div class="d-flex justify-content-center gap-3 flex-wrap">
                        @for (var i = 0; i < Model.Ctas.Length; i++)
                        {
                            var cta = Model.Ctas[i];
                            var buttonClass = i == 0 ? "btn btn-primary btn-lg" : "btn btn-outline-secondary btn-lg";

                            <a model="cta" class="@buttonClass"></a>
                        }
                    </div>
                }

            </div>
        </div>
    </div>
</section>
