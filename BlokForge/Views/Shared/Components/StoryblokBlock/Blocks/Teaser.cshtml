@model Teaser

<section class="py-5" @Html.StoryblokEditable(Model)>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm bg-body-tertiary">
                    <div class="card-body p-4 p-md-5 text-center">
                        <p class="text-uppercase text-primary fw-semibold small mb-3">Teaser</p>
                        <h2 class="display-6 fw-bold mb-0">@Model.Headline</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
